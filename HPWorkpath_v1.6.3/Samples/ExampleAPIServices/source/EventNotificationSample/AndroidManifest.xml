<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hp.workpath.sample.eventnotificationsample">

    <uses-permission android:name="com.hp.workpath.permission.RECEIVE_SIGN_IN_OUT_EVENT" />
    <uses-permission android:name="com.hp.workpath.permission.RECEIVE_JOB_COMPLETED_EVENT" />
    <uses-permission android:name="com.hp.workpath.permission.RECEIVE_CONFIG_CHANGED_EVENT" />
    <uses-permission android:name="com.hp.workpath.permission.RECEIVE_SLEEP_WAKEUP_EVENT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:hardwareAccelerated="false"
        android:theme="@style/DefaultTheme">

        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".EventInfoActivity"
            android:exported="true" />

        <receiver android:name=".receiver.SignInOutReceiver"
            android:permission="com.hp.workpath.permission.RECEIVE_SIGN_IN_OUT_EVENT"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.hp.workpath.action.SIGN_IN" />
                <action android:name="com.hp.workpath.action.SIGN_OUT" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.JobCompletedReceiver"
            android:permission="com.hp.workpath.permission.RECEIVE_JOB_COMPLETED_EVENT"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.hp.workpath.action.JOB_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ConfigChangedReceiver"
            android:permission="com.hp.workpath.permission.RECEIVE_CONFIG_CHANGED_EVENT"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.hp.workpath.action.CONFIG_CHANGED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.SleepWakeUpReceiver"
            android:permission="com.hp.workpath.permission.RECEIVE_SLEEP_WAKEUP_EVENT"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.hp.workpath.action.WAKE_UP" />
                <action android:name="com.hp.workpath.action.SLEEP" />
            </intent-filter>
        </receiver>

        <service
            android:name=".service.ForegroundService"
            android:enabled="true"
            android:exported="false" />
    </application>

</manifest>
