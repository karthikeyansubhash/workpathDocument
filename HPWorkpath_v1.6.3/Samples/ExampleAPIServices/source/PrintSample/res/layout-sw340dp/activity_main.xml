<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.hp.workpath.sample.printsample.MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_above="@id/footer"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="true"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/toolbar_height"
                    android:theme="@style/Theme.AppCompat.Light"
                    app:layout_scrollFlags="scroll|enterAlways"
                    app:title="@string/app_name">

                </com.google.android.material.appbar.MaterialToolbar>


            </com.google.android.material.appbar.AppBarLayout>

            <FrameLayout
                android:id="@+id/dataContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/buttonBarLayout"
                android:layout_marginLeft="@dimen/activity_vertical_margin"
                android:layout_marginRight="@dimen/activity_vertical_margin" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/action_bar_color"
        android:layout_marginLeft="@dimen/button_margin"
        android:layout_marginTop="@dimen/negative_margin2"
        android:layout_marginRight="@dimen/button_margin"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/negative_margin2"
        android:orientation="horizontal"
        android:padding="@dimen/negative_margin10">

        <Button
            android:id="@+id/loadCapsButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:text="@string/load_caps_button" />

        <Button
            android:id="@+id/loadDefaultsButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/load_defaults_button" />

        <Button
            android:id="@+id/addToBatchButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:maxLines="2"
            android:text="@string/addtobatch" />

        <Button
            android:id="@+id/listBatchJobButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:maxLines="2"
            android:text="@string/listbatchjob" />

        <Button
            android:id="@+id/printButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="@string/print_text"
            />

        <Button
            android:id="@+id/cancelButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="@string/cancel"
            />

        <Button
            android:id="@+id/getJobInfoButton"
            style="@style/ButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/getjobinfo_button" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginRight="@dimen/margin15"
        android:layout_marginBottom="@dimen/margin30"
        android:backgroundTint="@color/footer_text_color"
        android:clickable="true"
        android:focusable="true"
        app:fabSize="mini"
        android:src="@drawable/ic_settings"
        android:tint="@color/action_bar_color" />

    <View
        android:id="@+id/layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:tag="Screen_4.3_Inch" />

</RelativeLayout>

