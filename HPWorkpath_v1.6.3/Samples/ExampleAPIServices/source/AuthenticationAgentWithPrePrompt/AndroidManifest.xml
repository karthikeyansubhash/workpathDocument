<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hp.workpath.sample.authenticationpreprompt">

    <uses-permission android:name="com.hp.jetadvantage.link.permission.SERVICES_PERMISSION" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:hardwareAccelerated="false"
        android:theme="@style/DefaultTheme">

        <activity
            android:name=".AuthenticationActivity"
            android:windowSoftInputMode="stateHidden"
            android:exported="false"/>

        <service android:name=".AuthenticationService"
            android:permission="com.hp.jetadvantage.link.permission.SERVICES_PERMISSION"
            android:exported="true">
            <intent-filter>
                <action android:name="com.hp.jetadvantage.link.api.action.AUTHENTICATION" />
            </intent-filter>
        </service>
    </application>

</manifest>