<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/activity_vertical_margin"
    android:orientation="horizontal"
    tools:context="com.hp.workpath.sample.launchersample.MainActivity">

    <RelativeLayout
        android:layout_width="@dimen/width_0"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/activity_vertical_margin"
        android:layout_weight="1"
        android:background="@drawable/xml_border">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_margin="@dimen/margin_20"
            android:src="@drawable/signin_login_unlock_ic" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="@dimen/width_0"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/activity_vertical_margin"
        android:layout_weight="1"
        android:orientation="vertical">

        <Button
            android:id="@+id/goHomeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/button_height"
            android:enabled="false"
            android:text="@string/go_home" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/linkAppUuidEditText"
                android:layout_width="@dimen/width_0"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:hint="@string/hint_uuid"
                android:inputType="text"
                android:maxLength="36"
                android:maxLines="1"
                android:textColorHint="@android:color/darker_gray" />

            <Button
                android:id="@+id/linkAppLaunchButton"
                android:layout_width="@dimen/width_0"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:enabled="false"
                android:text="@string/link_app_launch" />

        </LinearLayout>

        <Button
            android:id="@+id/menuViewButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/open_menu_view" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/viewheight"
            android:layout_marginTop="@dimen/margin_5"
            android:background="@android:color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_with_accessory"
                android:textSize="@dimen/text_size" />

            <Spinner
                android:id="@+id/accessorySpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/getOwnedButton"
                    android:layout_width="@dimen/width_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/get_owned" />

                <Button
                    android:id="@+id/resendButton"
                    android:layout_width="@dimen/width_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/resend" />

                <Button
                    android:id="@+id/openButton"
                    android:layout_width="@dimen/width_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/open" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accessory_data"
                android:textSize="@dimen/text_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding_5"
                android:background="@drawable/xml_border"
                android:padding="@dimen/padding_5">

                <TextView
                    android:id="@+id/accessoryDataTextview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/yellow" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/padding_5"
                android:paddingBottom="@dimen/padding_5">

                <TextView
                    android:layout_width="@dimen/width_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/device_host_name"
                    android:textSize="@dimen/text_size" />

                <TextView
                    android:id="@+id/hostnameTextView"
                    android:layout_width="@dimen/width_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="3" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
