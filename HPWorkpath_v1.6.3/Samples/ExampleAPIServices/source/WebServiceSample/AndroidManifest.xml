<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hp.workpath.sample.webservice">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="com.hp.workpath.permission.servicemanager.ACCESS_WEBSERVICES" />

    <application
        android:allowBackup="false"
        android:hardwareAccelerated="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/DefaultTheme">

        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation"
            android:label="@string/app_name"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service android:name=".services.WebServiceTask"
            android:exported="true">
            <intent-filter>
                <action android:name="com.hp.workpath.api.action.WEBSERVICES" />
            </intent-filter>
        </service>


    </application>

</manifest>
