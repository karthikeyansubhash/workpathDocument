<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hp.workpath.sample.deviceusagesample">

    <uses-permission android:name="com.hp.workpath.permission.sdk.ACCESS_DEVICE_USAGE_PERMISSION" />

    <application
        android:allowBackup="false"
        android:hardwareAccelerated="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/DefaultTheme">
        <activity
            android:name=".CopyByMediaSizeActivity"
            android:exported="false" />
        <activity
            android:name=".PrintByMediaSizeActivity"
            android:exported="false" />
        <activity
            android:name=".FaxByMediaSizeActivity"
            android:exported="false" />
        <activity
            android:name=".PlexByMediaSizeActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation"
            android:label="@string/app_name"
            android:exported="true"
            android:windowSoftInputMode="stateAlwaysHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".JobCategoryAndMediaSizeActivity"
            android:exported="false"/>
        <activity android:name=".MediaSizeActivity"
            android:exported="false" />
    </application>

</manifest>