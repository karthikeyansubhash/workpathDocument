<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DefaultTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:textSize">@dimen/textsize_12</item>

    </style>

    <style name="ButtonBar" parent="Widget.AppCompat.Button.Small">
        <item name="android:layout_width">@dimen/width_80</item>
        <item name="android:layout_marginRight">@dimen/margin_5</item>
        <item name="android:layout_height">@dimen/height_38</item>
        <item name="android:textSize">@dimen/textsize_12</item>

    </style>

    <style name="OptionLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/height_42</item>

    </style>

    <style name="Toolbar" parent="Theme.AppCompat.Light" />

</resources>