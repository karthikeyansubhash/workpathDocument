<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:theme="@style/Widget.Design.AppBarLayout">

        <TextView
            android:id="@+id/appNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/margin_10"
            android:text="@string/app_name"
            android:textColor="@android:color/black"
            android:textSize="@dimen/app_title" />

        <TextView
            android:id="@+id/versionTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/margin_10"
            android:text="@string/version"
            android:textColor="@android:color/darker_gray" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RelativeLayout
            android:layout_width="@dimen/margin_0"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/image_height"
                android:layout_above="@+id/idLayout"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/margin_20"
                android:src="@drawable/signin_login_unlock_ic" />

            <LinearLayout
                android:id="@+id/idLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/passwordLayout"
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:weightSum="10">

                <EditText
                    android:id="@+id/idEditText"
                    android:layout_width="@dimen/margin_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:hint="@string/id" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/passwordLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/authTypeLayout"
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:weightSum="10">

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="@dimen/margin_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:hint="@string/password"
                    android:inputType="textPassword" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/authTypeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/buttonLayout"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/padding_10"
                    android:text="@string/authentication_type" />

                <Spinner
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:entries="@array/authType" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/signInButton"
                    style="@style/ButtonBar"
                    android:layout_width="@dimen/margin_0"
                    android:layout_margin="@dimen/margin_5"
                    android:layout_weight="1"
                    android:text="@string/sign_in" />

                <Button
                    android:id="@+id/failButton"
                    style="@style/ButtonBar"
                    android:layout_width="@dimen/margin_0"
                    android:layout_margin="@dimen/margin_5"
                    android:layout_weight="1"
                    android:text="@string/failed" />

                <Button
                    android:id="@+id/homeButton"
                    style="@style/ButtonBar"
                    android:layout_width="@dimen/margin_0"
                    android:layout_margin="@dimen/margin_5"
                    android:layout_weight="1"
                    android:text="@string/home" />

                <Button
                    android:id="@+id/backButton"
                    style="@style/ButtonBar"
                    android:layout_width="@dimen/margin_0"
                    android:layout_margin="@dimen/margin_5"
                    android:layout_weight="1"
                    android:text="@string/back" />

            </LinearLayout>

        </RelativeLayout>

        <LinearLayout
            android:layout_width="@dimen/margin_0"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/padding_10">

            <include layout="@layout/layout_manual_zone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>