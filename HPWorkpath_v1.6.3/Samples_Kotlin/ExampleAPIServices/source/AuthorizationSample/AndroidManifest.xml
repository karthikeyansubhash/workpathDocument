<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hp.workpath.sample.authorization">

    <uses-permission android:name="com.hp.jetadvantage.link.permission.SERVICES_PERMISSION" />
    <uses-permission android:name="com.hp.workpath.permission.AUTHORIZATION_PERMISSION" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:hardwareAccelerated="false"
        android:theme="@style/DefaultTheme">

        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|screenSize"
            android:exported="true"
            android:windowSoftInputMode="stateAlwaysHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver android:name=".receiver.AuthorizationRequestReceiver"
            android:exported="true"
            android:permission="com.hp.workpath.permission.AUTHORIZATION_PERMISSION">
            <intent-filter>
                <action android:name="com.hp.workpath.action.AUTHORIZATION_REQUEST" />
            </intent-filter>
        </receiver>

        <receiver android:name=".receiver.ChangeNotificationReceiver"
            android:exported="true"
            android:permission="com.hp.workpath.permission.AUTHORIZATION_PERMISSION">
            <intent-filter>
                <action android:name="com.hp.workpath.action.AUTHORIZATION_CHANGE_NOTIFICATION" />
            </intent-filter>
        </receiver>

        <service android:name=".service.AuthorizeUserService"
            android:exported="true"
            android:permission="com.hp.jetadvantage.link.permission.SERVICES_PERMISSION">
            <intent-filter>
                <action android:name="com.hp.workpath.api.action.AUTHORIZATION" />
            </intent-filter>
        </service>

    </application>

</manifest>
