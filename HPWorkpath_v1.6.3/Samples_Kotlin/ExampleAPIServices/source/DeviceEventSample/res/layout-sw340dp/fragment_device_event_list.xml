<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <com.google.android.material.appbar.AppBarLayout
                    android:id="@+id/appbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="true"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior">

                    <com.google.android.material.appbar.MaterialToolbar
                        android:id="@+id/toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/toolbar_height"
                        android:theme="@style/Toolbar"
                        app:layout_scrollFlags="scroll|enterAlways"
                        app:title="@string/app_name">

                    </com.google.android.material.appbar.MaterialToolbar>

                </com.google.android.material.appbar.AppBarLayout>

                <RelativeLayout
                    android:id="@+id/layoutTop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/activity_vertical_margin"
                    android:paddingTop="@dimen/layout_top_bottom_margin"
                    android:paddingEnd="@dimen/activity_vertical_margin"
                    android:paddingBottom="@dimen/layout_top_bottom_margin">

                    <TextView
                        android:id="@+id/totalTitleTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toLeftOf="@+id/totalTextView"
                        android:text="@string/total"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/totalTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toLeftOf="@+id/getDeviceEventListButton"
                        android:paddingLeft="@dimen/padding_10"
                        android:paddingRight="@dimen/padding_10"
                        android:text="0"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/getDeviceEventListButton"
                        android:layout_width="@dimen/width_35"
                        android:layout_height="@dimen/height_35"
                        android:layout_alignParentRight="true"
                        android:src="@android:drawable/stat_notify_sync" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/layoutCategory"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/adapter_height"
                    android:layout_below="@+id/layoutTop"
                    android:layout_marginLeft="@dimen/activity_vertical_margin"
                    android:layout_marginRight="@dimen/activity_vertical_margin"
                    android:background="@color/option_background_color"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/activity_vertical_margin"
                    android:paddingRight="@dimen/activity_vertical_margin">

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/number" />

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="5"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/title" />

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="@string/severity" />

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="3"
                        android:gravity="center"
                        android:text="@string/stateChangeType" />

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="@string/category" />

                    <TextView
                        android:layout_width="@dimen/width_0"
                        android:layout_height="match_parent"
                        android:layout_weight="3"
                        android:gravity="center"
                        android:text="@string/timestamp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/deviceEventListView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_above="@+id/layoutBottom"
                    android:layout_below="@+id/layoutCategory"
                    android:layout_marginLeft="@dimen/margin_32"
                    android:layout_marginRight="@dimen/margin_32"
                    android:fadeScrollbars="false"
                    android:nestedScrollingEnabled="true"
                    android:scrollbarSize="@dimen/scrollbar_size_2"
                    android:scrollbars="vertical"
                    app:reverseLayout="true"
                    app:stackFromEnd="true" />

                <TextView
                    android:id="@+id/noEventTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:text="@string/no_event"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutBottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentBottom="true"
                    android:layout_marginLeft="@dimen/activity_vertical_margin"
                    android:layout_marginRight="@dimen/activity_vertical_margin"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/activity_vertical_margin"
                    android:paddingTop="@dimen/layout_top_bottom_margin"
                    android:paddingEnd="@dimen/activity_vertical_margin"
                    android:paddingBottom="@dimen/layout_top_bottom_margin">

                    <TextView
                        android:id="@+id/eventTextView"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/height_100"
                        android:layout_margin="@dimen/layout_top_bottom_margin"
                        android:background="@drawable/xml_border_rectangle"
                        android:fadeScrollbars="false"
                        android:paddingLeft="@dimen/padding_10"
                        android:paddingRight="@dimen/padding_10"
                        android:scrollbarSize="@dimen/scrollbar_size_4"
                        android:scrollbars="vertical" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <View
            android:id="@+id/layout"
            android:layout_width="@dimen/width_0"
            android:layout_height="@dimen/height_0"
            android:tag="Screen_4.3_Inch" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone" />

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>