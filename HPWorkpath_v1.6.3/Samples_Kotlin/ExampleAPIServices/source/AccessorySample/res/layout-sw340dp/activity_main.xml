<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:theme="@style/Toolbar"
                app:layout_scrollFlags="scroll|enterAlways"
                app:title="@string/app_name">

            </com.google.android.material.appbar.MaterialToolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/buttonBarRow"
            android:layout_below="@+id/appbar"
            android:paddingLeft="@dimen/activity_vertical_margin"
            android:paddingRight="@dimen/activity_vertical_margin">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/accessoryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/accessory_info_height" />

                <include layout="@layout/layout_accessory_data" />

                <FrameLayout
                    android:id="@+id/accessoryListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <FrameLayout
                    android:id="@+id/accessoryReportContainer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/accessory_reportdata_height" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/buttonBarRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginTop="@dimen/negative_margin8"
            android:layout_marginBottom="@dimen/negative_margin8"
            android:background="@color/action_bar_color"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/negative_margin10"
            android:visibility="gone">

            <Button
                android:id="@+id/openButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/open_accessory" />

            <Button
                android:id="@+id/closeButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/close_accessory" />

            <Button
                android:id="@+id/startReadingButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/start_reading" />

            <Button
                android:id="@+id/stopReadingButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/stop_reading" />

            <Button
                android:id="@+id/readReportButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/read_report" />

            <Button
                android:id="@+id/writeReportButton"
                style="@style/FooterButtonTheme"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/write_report" />

        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_marginRight="@dimen/margin_15"
            android:layout_marginBottom="@dimen/margin_30"
            android:backgroundTint="@color/float_btn_color"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_settings"
            android:tint="@color/button_clicked"
            app:fabCustomSize="@dimen/float_btn_size" />

        <View
            android:id="@+id/layout"
            android:layout_width="@dimen/width_0"
            android:layout_height="@dimen/height_0"
            android:tag="Screen_4.3_Inch" />

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>